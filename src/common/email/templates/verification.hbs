<div style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 600px; margin: 0 auto; background: #f5f5f5;">
  <!-- Header -->
  <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 20px; text-align: center; color: white;">
    <h1 style="margin: 0; font-size: 32px; font-weight: bold;">{{appName}}</h1>
    <p style="margin: 10px 0 0 0; font-size: 16px; opacity: 0.9;">Verificação de Email</p>
  </div>

  <!-- Main Content -->
  <div style="background: white; padding: 40px 30px; margin: 20px;">
    <h2 style="color: #333; font-size: 24px; margin-bottom: 20px;">Olá {{name}},</h2>
    
    <p style="color: #666; font-size: 16px; line-height: 1.6; margin-bottom: 20px;">
      Para completar o seu registo no {{appName}}, por favor verifique o seu endereço de email.
    </p>

    <!-- Verification Code Section -->
    <div style="background: #f0f4ff; padding: 30px; border-radius: 8px; text-align: center; margin: 30px 0;">
      <p style="color: #667eea; font-size: 14px; font-weight: bold; margin: 0 0 10px 0; text-transform: uppercase;">Seu Código de Verificação:</p>
      <div style="background: white; padding: 20px; border-radius: 5px; border: 2px dashed #667eea;">
        <p style="font-size: 36px; font-weight: bold; color: #333; margin: 0; letter-spacing: 5px;">{{verificationCode}}</p>
      </div>
      <p style="color: #999; font-size: 12px; margin: 10px 0 0 0;">Este código expira em {{expiryTime}}</p>
    </div>

    <!-- CTA Button -->
    <div style="text-align: center; margin: 30px 0;">
      <a href="{{verificationUrl}}" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 14px 40px; text-decoration: none; border-radius: 5px; font-weight: bold; font-size: 16px; display: inline-block;">
        Verificar Email
      </a>
    </div>

    <!-- Info Section -->
    <div style="background: #fff3cd; padding: 15px; border-left: 4px solid #ffc107; margin: 30px 0;">
      <p style="color: #856404; margin: 0; font-size: 14px;">
        <strong>Nota:</strong> Se não solicitou este código, por favor ignore este email. A conta não será ativada.
      </p>
    </div>

    <p style="color: #666; font-size: 14px; line-height: 1.6; margin-top: 30px;">
      Problemas? <a href="mailto:{{supportEmail}}" style="color: #667eea; text-decoration: none;">Contacte o nosso suporte</a>.
    </p>
  </div>

  <!-- Footer -->
  <div style="background: #f5f5f5; padding: 20px; text-align: center; color: #999; font-size: 12px; border-top: 1px solid #e0e0e0;">
    <p style="margin: 0;">© {{year}} {{appName}}. Todos os direitos reservados.</p>
    <p style="margin: 5px 0 0 0;">
      <a href="{{privacyUrl}}" style="color: #667eea; text-decoration: none;">Privacidade</a> |
      <a href="{{termsUrl}}" style="color: #667eea; text-decoration: none;">Termos</a> |
      <a href="{{supportUrl}}" style="color: #667eea; text-decoration: none;">Suporte</a>
    </p>
  </div>
</div>
