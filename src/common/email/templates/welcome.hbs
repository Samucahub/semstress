<div style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 600px; margin: 0 auto; background: #f5f5f5;">
  <!-- Header -->
  <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 20px; text-align: center; color: white;">
    <h1 style="margin: 0; font-size: 32px; font-weight: bold;">{{appName}}</h1>
    <p style="margin: 10px 0 0 0; font-size: 16px; opacity: 0.9;">Bem-vindo ao {{appName}}</p>
  </div>

  <!-- Main Content -->
  <div style="background: white; padding: 40px 30px; margin: 20px;">
    <h2 style="color: #333; font-size: 24px; margin-bottom: 20px;">Olá {{name}},</h2>
    
    <p style="color: #666; font-size: 16px; line-height: 1.6; margin-bottom: 20px;">
      Obrigado por se registar no {{appName}}! Estamos muito felizes em ter você na nossa comunidade.
    </p>

    <p style="color: #666; font-size: 16px; line-height: 1.6; margin-bottom: 30px;">
      Sua conta foi criada com sucesso. Agora você pode aproveitar todos os recursos do {{appName}}.
    </p>

    <!-- CTA Button -->
    <div style="text-align: center; margin: 40px 0;">
      <a href="{{actionUrl}}" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 14px 40px; text-decoration: none; border-radius: 5px; font-weight: bold; font-size: 16px; display: inline-block;">
        Começar Agora
      </a>
    </div>

    <!-- Info Section -->
    <div style="background: #f8f9fa; padding: 20px; border-left: 4px solid #667eea; margin: 30px 0;">
      <p style="color: #333; font-weight: bold; margin-top: 0;">Próximos Passos:</p>
      <ul style="color: #666; margin-bottom: 0; padding-left: 20px;">
        <li>Completar seu perfil</li>
        <li>Explorar os recursos disponíveis</li>
        <li>Convidar colegas para colaborar</li>
      </ul>
    </div>

    <p style="color: #666; font-size: 14px; line-height: 1.6; margin-top: 30px;">
      Se tiver dúvidas, não hesite em <a href="mailto:{{supportEmail}}" style="color: #667eea; text-decoration: none;">contactar o nosso suporte</a>.
    </p>
  </div>

  <!-- Footer -->
  <div style="background: #f5f5f5; padding: 20px; text-align: center; color: #999; font-size: 12px; border-top: 1px solid #e0e0e0;">
    <p style="margin: 0;">© {{year}} {{appName}}. Todos os direitos reservados.</p>
    <p style="margin: 5px 0 0 0;">
      <a href="{{privacyUrl}}" style="color: #667eea; text-decoration: none;">Privacidade</a> |
      <a href="{{termsUrl}}" style="color: #667eea; text-decoration: none;">Termos</a> |
      <a href="{{supportUrl}}" style="color: #667eea; text-decoration: none;">Suporte</a>
    </p>
  </div>
</div>
