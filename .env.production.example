# ========================
# Produção - Variáveis de Ambiente
# ========================
# IMPORTANTE: Copiar este ficheiro para .env.production e preencher TODOS os valores
# Para gerar secrets seguros: openssl rand -base64 64

# --- Base de Dados ---
POSTGRES_USER=cromometro
POSTGRES_PASSWORD=       # OBRIGATÓRIO: password forte (ex: openssl rand -base64 32)
POSTGRES_DB=cromometro

# --- Backend ---
JWT_SECRET=              # OBRIGATÓRIO: openssl rand -base64 64
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=    # OBRIGATÓRIO: openssl rand -base64 64
REFRESH_TOKEN_EXPIRY_DAYS=30
ADMIN_SETUP_KEY=         # OBRIGATÓRIO: chave forte para setup de admin

# --- URLs ---
FRONTEND_URL=https://cromometro.example.com
CORS_ORIGINS=https://cromometro.example.com
NEXT_PUBLIC_API_URL=https://api.cromometro.example.com

# --- OAuth (opcional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.cromometro.example.com/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.cromometro.example.com/auth/github/callback

# --- Email ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=true
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@cromometro.com
