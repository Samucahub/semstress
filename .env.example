# ========================
# Cromometro — Variáveis de Ambiente (Template)
# ========================
# Copiar para .env e preencher todos os valores
# Para gerar secrets: openssl rand -base64 64

# --- Ambiente ---
NODE_ENV="production"
PORT=3001

# --- Base de Dados ---
DATABASE_URL="postgresql://cromometro:CHANGE_ME_STRONG_PASSWORD@localhost:5432/cromometro"

# --- Autenticação JWT ---
JWT_SECRET="CHANGE_ME_USE_openssl_rand_base64_64"
JWT_EXPIRES_IN="24h"
REFRESH_TOKEN_SECRET="CHANGE_ME_USE_openssl_rand_base64_64"
REFRESH_TOKEN_EXPIRY_DAYS=30

# --- Admin Setup ---
# Chave para criar o primeiro utilizador admin via POST /auth/register-admin
# Após criar o admin, pode remover ou alterar esta chave
ADMIN_SETUP_KEY="CHANGE_ME_USE_openssl_rand_base64_32"

# --- URLs ---
FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
APP_URL="http://localhost:3000"

# --- OAuth (Google) ---
GOOGLE_CLIENT_ID="google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# --- OAuth (GitHub) ---
GITHUB_CLIENT_ID="github-client-id"
GITHUB_CLIENT_SECRET="github-client-secret"
GITHUB_CALLBACK_URL="http://localhost:3001/auth/github/callback"

# --- Email (SMTP) ---
MAIL_HOST="localhost"
MAIL_PORT="1025"
MAIL_SECURE="false"
MAIL_USER=""
MAIL_PASS=""
MAIL_FROM="noreply@cromometro.com"

# --- Logging ---
LOG_LEVEL="warn"